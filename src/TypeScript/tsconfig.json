{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "outDir": "../build",
    "rootDir": ".",
    "strict": true,
    "sourceMap": true,
    "lib": ["ES2020", "DOM"],
    "declaration": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["./**/*.ts"]
}
